# Copy this file to `.env` and fill in values.

# Anthropic API (for the Claude Agent SDK implementation)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Data paths — defaults are repository-relative and work out-of-the-box
PAPERS_DIR=./data/papers
GROUND_TRUTH_PATH=./data/ground_truth/all_combined_extracted_data_refined.xlsx
OUTPUTS_DIR=./outputs
LOGS_DIR=./logs

# Extraction settings
MAX_ITERATIONS=3
MAX_PAGES=20
